{
  "name": "jarvis-ui",
  "version": "0.1.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"vite\" \"wait-on tcp:5174 && electron .\"",
    "dev:safe": "concurrently \"vite\" \"wait-on tcp:5174 && electron . --disable-gpu --no-sandbox\"",
    "build": "vite build"
  },
  "dependencies": {
    "@react-three/drei": "^9.117.3",
    "@react-three/fiber": "^8.17.10",
    "framer-motion": "^11.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^38.1.2",
    "esbuild": "^0.27.3",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "vite": "^7.3.1",
    "wait-on": "^8.0.3"
  }
}
