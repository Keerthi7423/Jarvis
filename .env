# Jarvis Environment Configuration
PYTHONPATH=.

# ============================================================================
# TEXT-TO-SPEECH (TTS) CONFIGURATION
# ============================================================================
# Options: "elevenlabs", "coqui", "fallback"
TTS_BACKEND=fallback

# ELEVENLABS SETTINGS (For the high-quality Iron Man / Marcus voice)
# Get your key at: https://elevenlabs.io
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=pNInz6ovClq8tc97oR3m
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# ============================================================================
# ASSISTANT BEHAVIOR
# ============================================================================
SPEECH_RATE=160
ASSISTANT_WAKE_COOLDOWN_SECONDS=1.5

# ============================================================================
# UI BRIDGE
# ============================================================================
WS_BRIDGE_ENABLED=true
WS_BRIDGE_HOST=127.0.0.1
WS_BRIDGE_PORT=8765

# ============================================================================
# OLLAMA CONFIGURATION
# ============================================================================
OLLAMA_MODEL=gemma3:1b
